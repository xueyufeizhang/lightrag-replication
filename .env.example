# --- LLM backend selection ---
# "ollama" for a local Ollama server, "api" for any OpenAI-compatible endpoint
LLM_BACKEND=ollama

# Number of chunks processed concurrently during extraction
CON_NUM=4

# --- Ollama backend (used when LLM_BACKEND=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text

# --- OpenAI-compatible API backend (used when LLM_BACKEND=api) ---
API_BASE_URL=
API_KEY=
API_MODEL=

# Per-request timeout (seconds) for both extraction and embedding calls
EXTRACTION_TIMEOUT=600

# --- Storage ---
# Directory where per-document KV stores, vector indexes and the graph are persisted
WORKING_DIR=./dickens

# --- Chunking ---
CHUNK_SIZE=1200
CHUNK_OVERLAP_SIZE=100

# --- Retrieve ---
CHUNK_TOP_K=5
ENTITY_TOP_K=5
RELATION_TOP_K=5
